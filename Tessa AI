        display:flex; align-items:center; gap:7px;
        padding:0 20px; height:100%;
        background:transparent; border:none; border-bottom:3px solid transparent;
        margin-bottom:-2px;
        color:#6A6050; cursor:pointer;
        font-family:'DM Mono',monospace; font-size:10.5px;
        letter-spacing:2px; text-transform:uppercase;
        transition:all .18s; position:relative;
      }
      .nav-tab:hover { color:#EDE8DC; }
      .nav-tab--on { color:#C8A96E; border-bottom-color:#C8A96E; }
      .tab-glyph { font-size:15px; line-height:1; }
      .tab-badge {
        background:#C8A96E; color:#0E0C0A;
        border-radius:99px; padding:1px 7px;
        font-size:9px; font-weight:500; letter-spacing:0;
      }

      .nav-right { display:flex; align-items:center; gap:10px; margin-left:24px; }
      .files-pill {
        background:rgba(200,169,110,0.12); border:1px solid #9A7A45;
        border-radius:4px; padding:3px 10px;
        font-size:9px; color:#C8A96E; letter-spacing:1.5px; text-transform:uppercase;
      }
      .nav-icon-btn {
        background:transparent; border:1px solid #2A2520; border-radius:6px;
        padding:7px 11px; color:#6A6050; cursor:pointer;
        font-size:15px; line-height:1; transition:all .18s;
      }
      .nav-icon-btn:hover { border-color:#9A7A45; color:#C8A96E; }

      /* ─── MAIN ────────────────────────────────────────────────────── */
      .main-area {
        flex:1; display:flex; flex-direction:column;
        overflow:hidden; position:relative; z-index:1;
      }

      /* ─── CHAT ────────────────────────────────────────────────────── */
      .chat-wrap {
        flex:1; display:flex; flex-direction:column;
        max-width:760px; width:100%; margin:0 auto;
        min-height:0;
      }

      .msg-stream {
        flex:1; overflow-y:auto; padding:36px 20px 16px;
        display:flex; flex-direction:column; gap:0;
      }
      .msg-stream::-webkit-scrollbar { width:3px; }
      .msg-stream::-webkit-scrollbar-thumb { background:#D9D0BE; border-radius:3px; }

      .msg-row { margin-bottom:22px; animation:slideIn .2s ease; }
      .msg-row--user { display:flex; flex-direction:column; align-items:flex-end; }
      .msg-row--ai   { display:flex; flex-direction:column; align-items:flex-start; }

      .ai-label {
        display:flex; align-items:center; gap:6px;
        font-size:9px; font-weight:500; letter-spacing:2.5px; text-transform:uppercase;
        color:#8A8070; margin-bottom:7px;
      }
      .ai-glyph { color:#C8A96E; font-size:14px; }
      .searched-badge {
        background:#0E0C0A; color:#C8A96E;
        border:1px solid #9A7A45; border-radius:3px;
        padding:1px 7px; font-size:8px; letter-spacing:2px; text-transform:uppercase;
      }

      .bubble {
        max-width:70%; padding:14px 20px;
        font-family:'DM Mono',monospace; font-size:13.5px; line-height:1.85;
        word-break:break-word;
      }
      .bubble--ai {
        background:#0E0C0A; color:#EDE8DC;
        border-radius:2px 18px 18px 18px;
        border-left:3px solid #9A7A45;
      }
      .bubble--user {
        background:#EDE8DC; color:#0E0C0A;
        border-radius:18px 2px 18px 18px;
        border:1px solid #D5CCBA; border-right:3px solid #C8A96E;
      }
      .bubble--err { border-left-color:#C0392B; }
      .bubble--thinking {
        display:flex; align-items:center; gap:8px; padding:16px 20px;
      }

      .t-dot {
        width:7px; height:7px; border-radius:50%;
        background:#C8A96E; display:inline-block;
      }
      .t-dot:nth-child(1){animation:td 1.1s ease-in-out infinite 0s;}
      .t-dot:nth-child(2){animation:td 1.1s ease-in-out infinite .18s;}
      .t-dot:nth-child(3){animation:td 1.1s ease-in-out infinite .36s;}

      .msg-time { font-size:9px; color:#8A8070; letter-spacing:1px; margin-top:5px; }
      .msg-time--r { text-align:right; }

      .icode {
        background:rgba(200,169,110,0.1); color:#9A7A45;
        padding:1px 6px; border-radius:3px; font-size:12px;
        border:1px solid rgba(200,169,110,0.2);
      }

      /* ─── INPUT DOCK ──────────────────────────────────────────────── */
      .input-dock {
        border-top:1px solid #D9D0BE;
        background:#F5F0E8;
        padding:14px 20px 18px;
        flex-shrink:0;
      }

      .active-files-bar { display:flex; gap:8px; flex-wrap:wrap; margin-bottom:10px; }
      .af-tag {
        background:rgba(14,12,10,0.05); border:1px solid #D9D0BE;
        border-radius:4px; padding:3px 8px 3px 10px;
        font-size:10px; color:#4A4540; display:flex; align-items:center; gap:6px;
        font-family:'DM Mono',monospace;
      }
      .af-remove { background:none; border:none; cursor:pointer; color:#8A8070; font-size:14px; line-height:1; }

      .input-box {
        display:flex; gap:10px; align-items:flex-end;
        background:#0E0C0A; border:1px solid #2A2520;
        border-radius:12px; padding:4px 4px 4px 18px;
        transition:border-color .2s;
      }
      .input-box:focus-within { border-color:#9A7A45; }

      .chat-input {
        flex:1; background:transparent; border:none; outline:none;
        color:#EDE8DC; font-family:'DM Mono',monospace;
        font-size:13.5px; line-height:1.65; resize:none;
        max-height:150px; overflow-y:auto; padding:10px 0;
        caret-color:#C8A96E;
      }
      .chat-input::placeholder { color:#3A3530; }

      .send-btn {
        width:42px; height:42px; border-radius:9px; flex-shrink:0;
        background:#C8A96E; border:none; cursor:pointer;
        color:#0E0C0A; font-size:19px; font-weight:700;
        display:flex; align-items:center; justify-content:center;
        transition:all .18s;
      }
      .send-btn--off { background:#2A2520; color:#4A4540; cursor:not-allowed; }
      .send-btn:not(.send-btn--off):hover { background:#9A7A45; }

      .spin { display:inline-block; animation:rotate .8s linear infinite; }

      .input-meta {
        display:flex; gap:18px; margin-top:8px;
        font-size:9px; letter-spacing:1.2px; color:#B0A898; text-transform:uppercase;
      }

      /* ─── WELCOME ─────────────────────────────────────────────────── */
      .welcome {
        margin:auto; text-align:center;
        padding:52px 24px; max-width:600px;
        animation:fadeIn .5s ease;
      }
      .welcome-mark {
        width:76px; height:76px; border-radius:16px;
        background:#0E0C0A; color:#C8A96E;
        font-family:'Playfair Display',serif; font-size:44px; font-weight:900;
        display:flex; align-items:center; justify-content:center;
        margin:0 auto 30px;
        box-shadow:0 10px 40px rgba(14,12,10,0.22);
      }
      .welcome-heading {
        font-family:'Playfair Display',serif; font-size:44px;
        font-weight:900; color:#0E0C0A; letter-spacing:-1.5px;
        line-height:1.1; margin-bottom:14px;
      }
      .welcome-body {
        font-size:13px; color:#8A8070; line-height:1.9;
        margin-bottom:38px;
      }
      .chips-grid {
        display:grid; grid-template-columns:1fr 1fr; gap:10px;
        max-width:520px; margin:0 auto;
      }
      .chip {
        background:#0E0C0A; border:1px solid #2A2520;
        border-radius:7px; padding:13px 16px;
        color:#9A9080; font-family:'DM Mono',monospace;
        font-size:11.5px; cursor:pointer; text-align:left;
        line-height:1.5; transition:all .18s;
      }
      .chip:hover { background:#1C1916; border-color:#9A7A45; color:#C8A96E; }

      /* ─── PANELS ──────────────────────────────────────────────────── */
      .panel-wrap {
        max-width:880px; width:100%; margin:0 auto;
        padding:40px 28px; overflow-y:auto; flex:1;
        animation:fadeIn .3s ease;
      }
      .panel-hero {
        display:flex; align-items:flex-end; justify-content:space-between;
        padding-bottom:28px; margin-bottom:28px;
        border-bottom:1px solid #D9D0BE; flex-wrap:wrap; gap:16px;
      }
      .panel-eyebrow {
        font-size:9px; font-weight:500; letter-spacing:3.5px;
        color:#C8A96E; margin-bottom:7px; text-transform:uppercase;
      }
      .panel-title {
        font-family:'Playfair Display',serif; font-size:38px;
        font-weight:900; letter-spacing:-1.2px; color:#0E0C0A; line-height:1.1;
      }
      .panel-sub { font-size:12px; color:#8A8070; margin-top:6px; }

      .big-add-btn {
        display:flex; align-items:center; gap:9px;
        background:#0E0C0A; color:#C8A96E;
        border:1px solid #9A7A45; border-radius:8px;
        padding:12px 22px; cursor:pointer;
        font-family:'DM Mono',monospace; font-size:11px;
        letter-spacing:1.5px; text-transform:uppercase; transition:all .18s;
      }
      .big-add-btn:hover { background:#C8A96E; color:#0E0C0A; border-color:#C8A96E; }
      .big-add-glyph { font-size:18px; }

      /* Files table */
      .files-table { display:flex; flex-direction:column; }
      .files-thead {
        display:grid; grid-template-columns:2.5fr 90px 80px 160px 90px;
        padding:8px 16px; gap:12px;
        font-size:9px; letter-spacing:2.5px; color:#8A8070; text-transform:uppercase;
        border-bottom:1px solid #D9D0BE; margin-bottom:4px;
      }
      .files-row {
        display:grid; grid-template-columns:2.5fr 90px 80px 160px 90px;
        align-items:center; gap:12px;
        padding:14px 16px; border-bottom:1px solid #EDE8DC;
        font-size:12px; animation:rowIn .25s ease both;
        animation-delay:calc(var(--i)*40ms); transition:background .15s;
      }
      .files-row:hover { background:#EDE8DC; }
      .frow-name { display:flex; align-items:center; gap:10px; color:#0E0C0A; font-weight:500; overflow:hidden; white-space:nowrap; text-overflow:ellipsis; }
      .frow-icon { font-size:16px; flex-shrink:0; }
      .frow-badge {
        background:rgba(14,12,10,0.07); border:1px solid #D9D0BE;
        border-radius:4px; padding:2px 8px; font-size:10px; color:#4A4540;
        display:inline-block; text-align:center;
      }
      .frow-muted { color:#8A8070; font-size:11px; }
      .frow-del {
        background:none; border:1px solid #D9D0BE;
        border-radius:4px; padding:4px 10px;
        font-size:10px; color:#8A8070; cursor:pointer;
        font-family:'DM Mono',monospace; letter-spacing:.5px; transition:all .15s;
      }
      .frow-del:hover { border-color:#C0392B; color:#C0392B; background:rgba(192,57,43,0.04); }

      /* Reminders */
      .rem-section-label {
        font-size:9px; letter-spacing:3px; color:#8A8070;
        text-transform:uppercase; margin-bottom:14px;
      }
      .rem-list { display:flex; flex-direction:column; gap:10px; }

      .rform {
        background:#EDE8DC; border:1px solid #D9D0BE;
        border-radius:12px; padding:24px; margin-bottom:28px;
        animation:slideIn .22s ease;
      }
      .rform-grid { display:grid; grid-template-columns:1fr 1fr; gap:16px; }
      .rform-field { display:flex; flex-direction:column; gap:6px; }
      .rform-label {
        font-size:9px; letter-spacing:2px; color:#8A8070; text-transform:uppercase;
      }
      .rform-input {
        background:white; border:1px solid #D9D0BE; border-radius:6px;
        padding:11px 14px; font-family:'DM Mono',monospace; font-size:13px;
        color:#0E0C0A; outline:none; transition:border-color .18s;
      }
      .rform-input:focus { border-color:#9A7A45; }

      .rcard {
        display:flex; align-items:flex-start; gap:14px;
        background:white; border:1px solid #EDE8DC;
        border-radius:10px; padding:17px 18px;
        border-left:4px solid #C8A96E;
        animation:rowIn .25s ease both;
        animation-delay:calc(var(--i)*40ms);
        transition:box-shadow .18s;
      }
      .rcard:hover { box-shadow:0 4px 18px rgba(14,12,10,0.07); }
      .rcard--done { opacity:.5; border-left-color:#D9D0BE; }
      .rcard--overdue { border-left-color:#C0392B; }

      .rcard-check {
        width:22px; height:22px; border-radius:50%;
        border:2px solid #D9D0BE; background:transparent;
        cursor:pointer; flex-shrink:0; margin-top:2px;
        display:flex; align-items:center; justify-content:center;
        font-size:11px; font-weight:700; transition:all .18s; color:#0E0C0A;
      }
      .rcard-check--done { background:#C8A96E; border-color:#C8A96E; }
      .rcard-check:not(.rcard-check--done):hover { border-color:#9A7A45; }

      .rcard-body { flex:1; }
      .rcard-title { font-weight:500; font-size:14px; color:#0E0C0A; }
      .rcard-note  { font-size:11.5px; color:#8A8070; margin-top:3px; }
      .rcard-meta  { display:flex; gap:12px; align-items:center; margin-top:8px; flex-wrap:wrap; }
      .rcard-time  { font-size:10px; color:#8A8070; letter-spacing:.5px; }
      .rcard-countdown {
        font-size:10px; background:rgba(200,169,110,0.1);
        border:1px solid rgba(200,169,110,0.3); border-radius:4px;
        padding:2px 8px; color:#9A7A45; letter-spacing:.5px;
      }
      .rcard-countdown--late {
        background:rgba(192,57,43,0.07); border-color:rgba(192,57,43,0.3); color:#C0392B;
      }
      .rcard-del {
        background:none; border:none; cursor:pointer;
        color:#D9D0BE; font-size:20px; line-height:1;
        padding:0 4px; transition:color .15s;
      }
      .rcard-del:hover { color:#C0392B; }

      /* Empty */
      .empty-state {
        display:flex; flex-direction:column; align-items:center;
        text-align:center; padding:72px 24px; color:#8A8070;
      }
      .empty-glyph { font-size:48px; margin-bottom:16px; color:#D9D0BE; }
      .empty-title { font-family:'Playfair Display',serif; font-size:24px; color:#0E0C0A; margin-bottom:8px; }
      .empty-sub   { font-size:12px; max-width:320px; line-height:1.9; }

      /* Toast */
      .toast {
        position:fixed; bottom:28px; right:28px; z-index:9999;
        display:flex; align-items:center; gap:12px;
        background:#0E0C0A; border:1px solid #9A7A45;
        border-radius:8px; padding:14px 18px;
        min-width:260px; max-width:380px;
        box-shadow:0 16px 48px rgba(14,12,10,0.35);
        animation:toastIn .3s cubic-bezier(.34,1.3,.64,1);
      }
      .toast-icon { color:#C8A96E; font-size:15px; flex-shrink:0; }
      .toast-title { color:#EDE8DC; font-size:13px; font-weight:500; }
      .toast-body  { color:#6A6050; font-size:11px; margin-top:2px; }
      .toast-x { background:none; border:none; cursor:pointer; color:#4A4540; font-size:22px; line-height:1; padding:0 0 0 8px; }

      /* ─── Keyframes ───────────────────────────────────────────────── */
      @keyframes blink {
        0%,100%{opacity:1;} 50%{opacity:.25;}
      }
      @keyframes td {
        0%,100%{transform:translateY(0);opacity:.5;}
        50%{transform:translateY(-7px);opacity:1;}
      }
      @keyframes rotate {
        from{transform:rotate(0deg);}to{transform:rotate(360deg);}
      }
      @keyframes slideIn {
        from{opacity:0;transform:translateY(14px);}
        to{opacity:1;transform:translateY(0);}
      }
      @keyframes rowIn {
        from{opacity:0;transform:translateX(-10px);}
        to{opacity:1;transform:translateX(0);}
      }
      @keyframes fadeIn {
        from{opacity:0;}to{opacity:1;}
      }
      @keyframes toastIn {
        from{opacity:0;transform:translateY(16px) scale(.94);}
        to{opacity:1;transform:translateY(0) scale(1);}
      }

      @media (max-width:600px) {
        .nav-clock,.files-pill{display:none;}
        .nav-tab{padding:0 12px;}
        .tab-label{display:none;}
        .chips-grid,.rform-grid{grid-template-columns:1fr;}
        .files-thead{display:none;}
        .files-row{grid-template-columns:1fr auto;}
        .frow-badge,.frow-muted{display:none;}
